local function applyHoverTween(uiElement, endColor)
	local originalColor = uiElement.BackgroundColor3
	local tweenInfo = TweenInfo.new(0.2, Enum.EasingStyle.Quad, Enum.EasingDirection.Out)
	
	uiElement.MouseEnter:Connect(function()
		TweenService:Create(uiElement, tweenInfo, {BackgroundColor3 = endColor}):Play()
	end)
	uiElement.MouseLeave:Connect(function()
		TweenService:Create(uiElement, tweenInfo, {BackgroundColor3 = originalColor}):Play()
	end)
end

